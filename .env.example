# Database
DB_USER=plume
DB_PASS=plume_dev_password
DATABASE_URL=postgresql://plume:plume_dev_password@postgres:5432/plume_production

# Redis / Celery
REDIS_URL=redis://redis:6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# LLM (vLLM OpenAI-compatible endpoint). Leave empty to use the stub client.
VLLM_URL=
LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct

# Rails
RAILS_ENV=production
SECRET_KEY_BASE=change-me-in-prod

# Inter-service
AI_SERVICE_URL=http://ai-orchestrator:8000
RAILS_API_URL=http://api:3000
INTERNAL_API_KEY=change-me-in-prod

# Observability (optional)
SENTRY_DSN=
LOG_LEVEL=INFO
