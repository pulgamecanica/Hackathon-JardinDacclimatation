# ==========================================
# Database (PostgreSQL)
# ==========================================
POSTGRES_USER=plume
POSTGRES_PASSWORD=plume_dev_password
POSTGRES_DB=plume_development
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ==========================================
# Redis / Celery
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6380                    # Note: Redis container uses 6380, but standard is 6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# ==========================================
# Rails API
# ==========================================
RAILS_ENV=development
RAILS_MASTER_KEY=eaa404f8879db347bda0be35673d9f7d
RAILS_PORT=3000                    # Internal container port
RAILS_EXTERNAL_PORT=3001             # Host-exposed port

# ==========================================
# AI Orchestrator
# ==========================================
API_PORT=8000                      # Host port for AI service

# ==========================================
# Flower (Celery monitoring)
# ==========================================
FLOWER_PORT=5555
FLOWER_AUTH=admin:admin

# ==========================================
# Mailer (Mailcatcher)
# ==========================================
SMTP_HOST=mailcatcher
SMTP_PORT=1025

# ==========================================
# Inter-service URLs
# ==========================================
RAILS_API_URL=http://hackathon-api:${RAILS_PORT}
AI_SERVICE_URL=http://localhost:${API_PORT}
FRONTEND_URL=http://localhost:3000

# ==========================================
# LLM Configuration
# ==========================================
LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct
# Add real keys below to use actual providers:
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
VLLM_URL=
VLLM_API_KEY=EMPTY

# ==========================================
# Optional / Debug
# ==========================================
LOG_LEVEL=INFO
